{
  "name": "ai-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Server (local LLM via LM Studio) that chats about plants and controls IoT devices through the plant-tree MCP.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx src/eval/run.ts",
    "scrape": "tsx src/rag/scrape/run.ts",
    "mcp:catalog": "tsx scripts/mcp-catalog.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.0",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
