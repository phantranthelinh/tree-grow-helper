# HTTP server
PORT=8787

# --- LLM: these only PREFILL the setup form at /setup (no auto-connect) ---
# The actual provider/model is chosen in the UI and saved to data/llm-config.json.
# Default provider card to preselect: lmstudio | ollama | gemini | openai-compat
LLM_PROVIDER=lmstudio
# Base URL of an OpenAI-compatible server (LM Studio here; Ollama = :11434/v1)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
# Chat + embedding model identifiers as loaded in the provider
MODEL=qwen2.5-3b-instruct
EMBED_MODEL=text-embedding-bge-m3

# --- Setup behaviour ---
# Where the connected config is persisted (mount this path as a volume in Docker)
LLM_CONFIG_PATH=data/llm-config.json
# Connection probe timeout in ms (raise if Ollama cold-loads a model on first call)
SETUP_PROBE_TIMEOUT_MS=10000
# Set to 0 to never auto-open a browser on startup (default in Docker)
SETUP_OPEN_BROWSER=1

# --- plant-tree MCP (run with streamable-http transport) ---
# Like the LLM vars: MCP_URL only PREFILLS the setup form / is the fallback when
# no data/mcp-config.json exists. The URL chosen at /setup is saved there and wins.
MCP_URL=http://localhost:8000/mcp
MCP_CONFIG_PATH=data/mcp-config.json

# Agent behaviour
MAX_TOOL_STEPS=3
RAG_TOP_K=4
DEFAULT_PLANT=strawberry
